APP_ENV=development

# Backend API
API_PORT=8000

# Postgres
POSTGRES_USER=admin
POSTGRES_PASSWORD=secretpassword
POSTGRES_DB=recommender_db
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://admin:secretpassword@db:5432/recommender_db

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# ML / Recs
SBERT_MODEL=all-MiniLM-L6-v2
INGEST_SAMPLE_SIZE=25000
INGEST_BATCH_SIZE=128
CACHE_TTL=120

# Frontend (optional if running frontend via compose)
FRONTEND_PORT=5173
VITE_API_BASE=http://127.0.0.1:8000/api/v1
