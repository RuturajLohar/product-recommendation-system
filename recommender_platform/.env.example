# Copy this file to .env for local development.
# Never commit real .env files or real API keys.

# App
APP_ENV=development
PORT=8000
API_PORT=8000
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# PostgreSQL
# Local Docker Compose default:
POSTGRES_USER=admin
POSTGRES_PASSWORD=change_me_local_password
POSTGRES_DB=recommender_db
POSTGRES_HOST=db
POSTGRES_PORT=5432
DATABASE_URL=postgresql://admin:change_me_local_password@db:5432/recommender_db

# GCP Cloud SQL example:
# DATABASE_URL=postgresql://DB_USER:DB_PASSWORD:INSTANCE_CONNECTION_NAME/DB_NAME?host=/cloudsql/PROJECT_ID:REGION:INSTANCE_NAME

# Qdrant
# Local Docker Compose:
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_HTTPS=false
QDRANT_COLLECTION=products

# Qdrant Cloud / external Qdrant:
# QDRANT_URL=https://YOUR_CLUSTER_URL
# QDRANT_API_KEY=YOUR_QDRANT_API_KEY

# Redis
# For simple GCP demo deployments, Redis can be disabled.
REDIS_ENABLED=true
REDIS_HOST=redis
REDIS_PORT=6379
CACHE_TTL=120

# Recommendation engine
SBERT_MODEL=all-MiniLM-L6-v2
INGEST_SAMPLE_SIZE=100000
INGEST_BATCH_SIZE=256
RANKER_MODEL_PATH=

# Optional LLM enhancement. Keep false for low-cost deployment.
USE_LLM_RERANKING=false
GROQ_API_KEY=
GEMINI_API_KEY=

# Frontend
FRONTEND_PORT=5173
VITE_API_BASE=/api/v1
VITE_PROXY_API=http://api:8000

# For deployed frontend builds, set VITE_API_BASE to your backend URL:
# VITE_API_BASE=https://YOUR_BACKEND_URL/api/v1
